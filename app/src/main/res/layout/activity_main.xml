<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- ===== APP BAR ===== -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:elevation="4dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="VinzzRenderer"
            app:titleCentered="true"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ===== SCROLL CONTENT ===== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/option_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ===== GLSL CACHE ===== -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_max_glsl_cache_size_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="@string/option_glsl_cache"
                app:errorEnabled="true"
                app:helperText="@string/option_glsl_cache_helper"
                app:helperTextEnabled="true">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_max_glsl_cache_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberSigned"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ===== ANGLE ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/option_angle"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <Spinner
                android:id="@+id/spinner_angle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="48dp"/>

            <!-- ===== NO ERROR ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/option_no_error"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <Spinner
                android:id="@+id/spinner_no_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="48dp"/>

            <!-- ===== MULTIDRAW MODE ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/option_multidraw_mode"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <Spinner
                android:id="@+id/spinner_multidraw_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="48dp"/>

            <!-- ===== CUSTOM GL VERSION ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/option_custom_gl_version"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <Spinner
                android:id="@+id/spinner_custom_gl_version"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="48dp"/>

            <!-- ===== ANGLE CLEAR WORKAROUND ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/option_angle_clear_workaround"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <Spinner
                android:id="@+id/angle_clear_workaround"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:minHeight="48dp"/>

            <!-- ===== STANDARD TOGGLES ===== -->
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_ext_cs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/option_ext_cs"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_ext_timer_query"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/option_ext_timer_query"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_ext_direct_state_access"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/option_ext_direct_state_access"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_enable_fsr1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/option_enable_fsr1"/>

            <!-- ===== VINZZ: PERFORMANCE ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/vinzz_section_perf2"
                android:textAppearance="?attr/textAppearanceTitleMedium"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_sodium_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_sodium_mode_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_no_throttle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/vinzz_no_throttle"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_fast_hints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_fast_hints"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_disable_dither"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_disable_dither"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_state_cache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_state_cache"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_fbo_cache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_fbo_cache"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_skip_small_draws"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/vinzz_skip_small_draws"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_batch_uniforms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_batch_uniforms_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_multidraw_sodium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_multidraw_sodium"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_qcom_tiling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_qcom_tiling"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_fence_pool"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_fence_pool"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_disjoint_timer_off"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_disjoint_timer_off"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_smart_invalidate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_smart_invalidate"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_color_invalidate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/vinzz_color_invalidate"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_persistent_vbo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_persistent_vbo"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_index_reuse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/vinzz_index_reuse"/>

            <!-- ===== VINZZ: TEXTURE ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/vinzz_section_texture"
                android:textAppearance="?attr/textAppearanceTitleMedium"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:text="@string/vinzz_anisotropic_label"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:alpha="0.6"
                android:text="@string/vinzz_anisotropic_hint"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_anisotropic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:stepSize="1"
                android:value="3"
                android:valueFrom="1"
                android:valueTo="5"/>
            <TextView
                android:id="@+id/text_anisotropic_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="4x"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:text="@string/vinzz_mip_bias_label"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:alpha="0.6"
                android:text="@string/vinzz_mip_bias_hint"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_mip_bias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:stepSize="1"
                android:value="-5"
                android:valueFrom="-10"
                android:valueTo="10"/>
            <TextView
                android:id="@+id/text_mip_bias_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="-0.5"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_tex_cache"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_tex_cache_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_astc_prefer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:checked="true"
                android:text="@string/vinzz_astc_prefer_label"/>

            <!-- ===== VINZZ: SHADER ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/vinzz_section_shader"
                android:textAppearance="?attr/textAppearanceTitleMedium"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_shader_cache_aggressive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_shader_cache"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_glsl_pragma_opt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/vinzz_glsl_pragma"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_reduce_precision"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/vinzz_reduce_precision_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_mediump_fragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/vinzz_mediump_fragment_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_early_z"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_early_z_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_lrz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_lrz_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_vertex_mediump"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_vertex_mediump_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_invariant_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_invariant_strip_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_precise_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:checked="true"
                android:text="@string/vinzz_precise_strip_label"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_fp16_varyings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/vinzz_fp16_varyings_label"/>

            <!-- ===== VINZZ: NEW 5 FEATURES ===== -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:layout_marginBottom="4dp"
                android:text="@string/vinzz_section_new5"
                android:textAppearance="?attr/textAppearanceTitleMedium"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" android:alpha="0.7"
                android:text="@string/vinzz_buffer_streaming_desc"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_buffer_streaming"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:checked="true"
                android:text="@string/vinzz_buffer_streaming_label"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" android:alpha="0.7"
                android:text="@string/vinzz_cpu_preprep_desc"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_cpu_preprep"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:checked="true"
                android:text="@string/vinzz_cpu_preprep_label"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" android:alpha="0.7"
                android:text="@string/vinzz_denoiser_desc"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_denoiser"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:checked="true"
                android:text="@string/vinzz_denoiser_label"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" android:alpha="0.7"
                android:text="@string/vinzz_async_shader_desc"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_async_shader"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:checked="true"
                android:text="@string/vinzz_async_shader_label"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" android:alpha="0.7"
                android:text="@string/vinzz_pipeline_cache_desc"
                android:textAppearance="?attr/textAppearanceBodySmall"/>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_pipeline_cache"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:checked="true"
                android:text="@string/vinzz_pipeline_cache_label"/>

            <!-- ===== VINZZ: VULKAN MODE ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/vinzz_section_vulkan"
                android:textAppearance="?attr/textAppearanceTitleMedium"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:alpha="0.7"
                android:text="@string/vinzz_vulkan_mode_desc"
                android:textAppearance="?attr/textAppearanceBodySmall"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_vinzz_vulkan_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/vinzz_vulkan_mode_label"/>

            <!-- Vulkan sub-options: visible hanya saat Vulkan Mode ON -->
            <LinearLayout
                android:id="@+id/layout_vulkan_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_vinzz_vulkan_lwjgl_patch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:checked="true"
                    android:text="@string/vinzz_vulkan_lwjgl_patch_label"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_vinzz_vulkan_async_compute"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:checked="true"
                    android:text="@string/vinzz_vulkan_async_compute_label"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_vinzz_vulkan_vma_defrag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:checked="true"
                    android:text="@string/vinzz_vulkan_vma_defrag_label"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_vinzz_vulkan_disable_validation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:checked="true"
                    android:text="@string/vinzz_vulkan_disable_validation_label"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_vinzz_vulkan_memory_budget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:checked="true"
                    android:text="@string/vinzz_vulkan_memory_budget_label"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_vinzz_vulkan_spirv_opt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:checked="true"
                    android:text="@string/vinzz_vulkan_spirv_opt_label"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_vinzz_vulkan_frame_overlap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:checked="true"
                    android:text="@string/vinzz_vulkan_frame_overlap_label"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== OPEN OPTIONS BUTTON ===== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/open_options"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/open_options"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
